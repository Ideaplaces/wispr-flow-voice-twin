#!/usr/bin/env python3
"""Voice twin CLI.

Examples:
    voice slack "let the team know I'm taking the morning to work on c3 mobile layout"
    voice blog "the two voices: how I talk to AI vs how I talk to humans"
    voice email --body "$(pbpaste)" "draft a reply"
    voice coach --body "$(pbpaste)" "tighten this up"

The CLI is a thin wrapper over agent/twin.py. It loads the .env, dispatches
to the agent, and prints the draft. Retrieval picks similar past dictations
from your local Chroma collection and includes them as in-context examples.
"""

import argparse
import os
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(ROOT))

# Load .env before importing config so secrets propagate
ENV = ROOT / ".env"
if ENV.exists():
    for line in ENV.read_text().splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        k, v = line.split("=", 1)
        os.environ.setdefault(k.strip(), v.strip().strip('"').strip("'"))

from agent import twin  # noqa: E402


MODES = ["slack", "blog", "email", "coach"]


def main():
    ap = argparse.ArgumentParser(prog="voice", description="Voice twin")
    ap.add_argument("mode", choices=MODES)
    ap.add_argument("topic", help="The topic, prompt, or instruction")
    ap.add_argument("--body", help="Optional input body (e.g. paste a thread)")
    ap.add_argument("-k", "--retrieve", type=int, default=None,
                    help="How many past dictations to retrieve (default 8)")
    ap.add_argument("--show-retrieved", action="store_true",
                    help="Print the retrieved examples used for context")
    args = ap.parse_args()

    out, source, retrieved = twin.speak(args.mode, args.topic, body=args.body, k=args.retrieve)

    if args.show_retrieved:
        sys.stderr.write(f"\n--- Retrieved {len(retrieved)} examples ---\n")
        for i, r in enumerate(retrieved, 1):
            sys.stderr.write(f"[{i}] sim={r['sim']:.2f} ctx={r['meta']['ctx']} "
                             f"ts={r['meta'].get('ts','')}\n")
            sys.stderr.write(f"    {r['doc'][:200]}\n")
        sys.stderr.write("--- End retrieved ---\n\n")

    print(out)
    sys.stderr.write(f"\n[generated by {source}]\n")


if __name__ == "__main__":
    main()
