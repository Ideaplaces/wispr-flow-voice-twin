# wispr-flow-voice-twin configuration. Copy to .env and edit.

# ---------------------------------------------------------------------------
# Source data
# ---------------------------------------------------------------------------
# Wispr Flow's live SQLite. Default is the macOS install path.
# FLOW_SQLITE_PATH=/Users/yourname/Library/Application Support/Wispr Flow/flow.sqlite

# ---------------------------------------------------------------------------
# LLM provider (chat + embeddings)
# ---------------------------------------------------------------------------
# Azure OpenAI (preferred). The same resource provides both chat and embeddings.
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-key-here
AZURE_OPENAI_API_VERSION=2024-02-01

# Chat model. gpt-4o-mini works but gpt-4o or gpt-4.1 produce noticeably
# more authentic voice imitation. Use whichever deployment you have.
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini

# Embedding model. text-embedding-3-large is the default and recommended
# (3072 dim, ~$0.50 to embed all 27k dictations once).
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# ---------------------------------------------------------------------------
# Anthropic (optional fallback)
# ---------------------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ---------------------------------------------------------------------------
# Embedding provider override
# ---------------------------------------------------------------------------
# auto (default): use Azure if keys are set, else local sentence-transformers.
# azure: force Azure (will fail without keys).
# local: force local (no network, no API costs, slower).
EMBED_PROVIDER=auto
LOCAL_EMBED_MODEL=sentence-transformers/all-mpnet-base-v2

# ---------------------------------------------------------------------------
# Retrieval tuning
# ---------------------------------------------------------------------------
RETRIEVE_K=8
MIN_WORDS_FOR_INDEX=5
SAME_CONTEXT_BIAS=0.85
