# wispr-flow-voice-twin configuration. Copy this file to .env and edit.
#
# Privacy: nothing in here changes the local-first default. With everything
# commented out (and Ollama running), the system makes no outbound calls.
# Cloud providers are opt-in.

# ---------------------------------------------------------------------------
# Personal profile (REQUIRED, but lives outside the repo)
# ---------------------------------------------------------------------------
# Your private profile.md path or https URL. Copy profile.example.md to a
# location of your choice and point this variable at it. The repo never
# persists a copy.
VOICE_TWIN_PROFILE=/home/yourname/.voice-twin/profile.md

# ---------------------------------------------------------------------------
# Source data
# ---------------------------------------------------------------------------
# Wispr Flow's live SQLite. Auto-detected on macOS by default.
# FLOW_SQLITE_PATH=/Users/yourname/Library/Application Support/Wispr Flow/flow.sqlite

# ---------------------------------------------------------------------------
# Provider selection
# ---------------------------------------------------------------------------
# auto: prefer cloud creds if set, fall back to local.
# local: force fully local (sentence-transformers + Ollama). No network calls.
EMBED_PROVIDER=auto
LLM_PROVIDER=auto

# ---------------------------------------------------------------------------
# Local providers (no creds required)
# ---------------------------------------------------------------------------
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b
# LOCAL_EMBED_MODEL=sentence-transformers/all-mpnet-base-v2

# ---------------------------------------------------------------------------
# Azure OpenAI (chat + embeddings, opt-in)
# ---------------------------------------------------------------------------
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=your-key-here
# AZURE_OPENAI_API_VERSION=2024-02-01
# AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# ---------------------------------------------------------------------------
# OpenAI direct (chat + embeddings, opt-in)
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# Anthropic (chat only, opt-in)
# ---------------------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ---------------------------------------------------------------------------
# Retrieval tuning
# ---------------------------------------------------------------------------
RETRIEVE_K=8
MIN_WORDS_FOR_INDEX=5
SAME_CONTEXT_BIAS=0.85
